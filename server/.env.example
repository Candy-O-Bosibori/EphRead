# Copy this file to .env and fill in your values
# Never commit .env — only commit .env.example

# ── Local PostgreSQL (used in development only) ──────────────
# In production, set DATABASE_URL instead (Railway/Supabase provide this)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=rag_user
DB_PASSWORD=

# ── Production database (Railway or Supabase) ─────────────────
# Uncomment and set this when deploying — it overrides the DB_* vars above
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── API keys ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
